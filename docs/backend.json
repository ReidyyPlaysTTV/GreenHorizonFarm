
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about a farm employee.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique Firebase UID." },
        "username": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "roles": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of system roles."
        },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "username"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Stores user profile data."
    }
  }
}
